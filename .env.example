# ============================================================================
# Environment Variables Configuration
# ============================================================================
# Copy this file to .env and update with your actual values
# ============================================================================

# ============================================================================
# Database Configuration (PostgreSQL)
# ============================================================================
POSTGRES_HOST=db
POSTGRES_USER=admin
POSTGRES_PASSWORD=1234
POSTGRES_DB=meet_control

# ============================================================================
# JWT Authentication
# ============================================================================
JWT_SECRET=7bav55v-98ad-24vv-tbcc-af2884cefa6
JWT_ALGORITHM=HS256

# ============================================================================
# Super Admin Account (created on first run)
# ============================================================================
SUPER_ADMIN_USERNAME=admin
SUPER_ADMIN_PASSWORD=1234

# ============================================================================
# Database Reset (PRODUCTION: set to 0)
# ============================================================================
# Set to 1 only for a one-time fresh initialization, then back to 0
RESET_DB=0
USE_ALEMBIC=0

# ============================================================================
# CMS Configuration (Cisco Meeting Server - Audio and Video)
# ============================================================================
CMS_AUDIO_URL=https://192.168.20.200:445
CMS_VIDEO_URL=https://192.168.20.201:445
CMS_USERNAME=admin
CMS_PASSWORD=S@p180tech
CMS_TIMEOUT=30
CMS_VERIFY_SSL=false

# ============================================================================
# CORS Origins (comma-separated list of allowed frontend URLs)
# ============================================================================
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://127.0.0.1:5173,http://127.0.0.1:5174,http://192.168.1.30:5173,http://192.168.1.30

# ============================================================================
# Census API Configuration
# ============================================================================
CENSUS_HOST=192.168.1.30
CENSUS_PORT=8001
CENSUS_PROTOCOL=http

# ============================================================================
# Frontend Configuration
# ============================================================================
VITE_API_URL=http://localhost:8001
VITE_CMS_MODE=mock
VITE_CENSUS_URL=http://localhost:8001
